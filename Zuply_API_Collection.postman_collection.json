          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/sellers", "host": ["{{baseUrl}}"], "path": ["api", "admin", "sellers"] }
          }
        },
