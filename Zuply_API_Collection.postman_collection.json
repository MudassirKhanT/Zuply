    },
    {
      "name": "🖼️ Upload (Module 1 — Mudassir)",
      "item": [
        {
          "name": "Upload Image ✅",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a JPEG or PNG file (max 10MB)"
                }
              ]
            }
          }
        },
        {
          "name": "Upload Image — Invalid Type (expects 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Attach a .pdf or .gif to trigger the 400 Invalid file type error"
                }
              ]
            }
          }
        },
        {
          "name": "Upload Image — No Auth (expects 401)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "No Authorization header — should return 401"
                }
              ]
            }
          }
        },
        {
          "name": "Upload Image — Customer Token (expects 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Customer token — should return 403 Forbidden (only SELLER allowed)"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
