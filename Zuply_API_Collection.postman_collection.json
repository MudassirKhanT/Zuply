          "name": "Suspend Seller",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/sellers/1/suspend", "host": ["{{baseUrl}}"], "path": ["api", "admin", "sellers", "1", "suspend"] }
          }
        },
        {
          "name": "Get All Products (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/products", "host": ["{{baseUrl}}"], "path": ["api", "admin", "products"] }
          }
        },
        {
          "name": "Approve Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/products/1/approve", "host": ["{{baseUrl}}"], "path": ["api", "admin", "products", "1", "approve"] }
          }
        },
        {
          "name": "Reject Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
